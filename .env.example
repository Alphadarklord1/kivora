# Local Docker/Postgres development:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kivora

# Preferred hosted database for Kivora:
# SUPABASE_DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require
# Optional Supabase app keys if you later add Supabase client features:
# NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

AUTH_SECRET=replace-with-a-long-random-secret
AUTH_GUEST_MODE=1

# ── AI Providers ──────────────────────────────────────────────────────────────
# Primary cloud: Grok (xAI) — https://console.x.ai → API keys
# Get your key at: https://console.x.ai
GROK_API_KEY=xai-...
# Optional: pin a specific Grok model (default: grok-3-fast)
# GROK_MODEL_DEFAULT=grok-3-fast

# Secondary cloud fallback: OpenAI (used if Grok is unavailable or not configured)
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-4o-mini

# Local / offline AI feature: Ollama (runs models on the user's machine)
# Start Ollama: https://ollama.com — then: ollama pull mistral
# OLLAMA_URL=http://localhost:11434

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

NEXT_PUBLIC_APP_URL=https://study-alpha-three.vercel.app
