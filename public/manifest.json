{
  "name": "Kivora",
  "short_name": "Kivora",
  "description": "Your AI-powered study companion. Generate MCQs, summaries, quizzes, and study notes from any content.",
  "start_url": "/workspace",
  "id": "/workspace",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "browser"],
  "background_color": "#fafafa",
  "theme_color": "#2563eb",
  "orientation": "any",
  "scope": "/",
  "lang": "en",
  "dir": "ltr",
  "prefer_related_applications": false,
  "icons": [
    {
      "src": "/icons/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-192x192.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512x512.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-maskable.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "maskable"
    }
  ],
  "categories": ["education", "productivity", "utilities"],
  "shortcuts": [
    {
      "name": "Workspace",
      "short_name": "Workspace",
      "description": "Access your study folders and files",
      "url": "/workspace"
    },
    {
      "name": "Library",
      "short_name": "Library",
      "description": "View saved study materials",
      "url": "/library"
    },
    {
      "name": "Settings",
      "short_name": "Settings",
      "description": "Customize your experience",
      "url": "/settings"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/workspace.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Kivora Workspace"
    },
    {
      "src": "/screenshots/mobile.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Kivora Mobile"
    }
  ],
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": "navigate-existing"
  }
}
