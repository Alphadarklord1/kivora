{
  "name": "studypilot",
  "version": "1.1.0",
  "description": "Desktop-first AI study workspace",
  "private": true,
  "main": "electron/main.js",
  "author": "StudyPilot",
  "license": "MIT",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:https": "next dev --turbopack --experimental-https",
    "build": "next build",
    "build:stable": "NEXT_USE_TURBOPACK=0 next build",
    "export": "next build && next export",
    "start": "next start",
    "lint": "eslint",
    "test:policy": "node --test --experimental-strip-types tests/ai-policy.test.mjs",
    "electron:dev": "STUDYPILOT_DESKTOP_ONLY=1 AUTH_GUEST_MODE=1 concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "demo:local": "STUDYPILOT_DESKTOP_ONLY=1 LOCAL_DEMO_MODE=1 AUTH_GUEST_MODE=1 concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "STUDYPILOT_DESKTOP_ONLY=1 AUTH_GUEST_MODE=1 npm run build && electron-builder",
    "electron:build:mac": "STUDYPILOT_DESKTOP_ONLY=1 AUTH_GUEST_MODE=1 npm run build && electron-builder --mac --arm64",
    "electron:build:win": "STUDYPILOT_DESKTOP_ONLY=1 AUTH_GUEST_MODE=1 npm run build && electron-builder --win --x64",
    "electron:build:linux": "npm run build && electron-builder --linux",
    "electron:build:all": "npm run build && electron-builder -mwl",
    "models:prepare:laptop": "node scripts/prepare-model-bundle.js --target=laptop",
    "models:prepare:balanced": "node scripts/prepare-model-bundle.js --target=balanced",
    "models:prepare:pc": "node scripts/prepare-model-bundle.js --target=pc",
    "models:manifest:generate": "node scripts/generate-model-manifest.js",
    "models:manifest:validate": "node scripts/validate-model-manifest.js",
    "electron:build:mac:laptop": "npm run models:prepare:laptop && npm run electron:build:mac",
    "electron:build:mac:balanced": "npm run models:prepare:balanced && npm run electron:build:mac",
    "electron:build:mac:pc": "npm run models:prepare:pc && npm run electron:build:mac",
    "mobile:init": "npx cap init",
    "mobile:sync": "npx cap sync",
    "mobile:android": "npx cap open android",
    "mobile:ios": "npx cap open ios"
  },
  "build": {
    "appId": "com.studypilot.app",
    "productName": "StudyPilot",
    "asar": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "public/**/*",
      ".next/**/*",
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/runtime/models",
        "to": "models",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "electron/runtime/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.education",
      "icon": "public/icons/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "public/icons/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "public/icons/icon.png",
      "category": "Education",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icons/icon.png",
      "uninstallerIcon": "public/icons/icon.png"
    }
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@mintplex-labs/piper-tts-web": "^1.0.4",
    "@neondatabase/serverless": "^1.0.2",
    "@tanstack/react-query": "^5.90.19",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "function-plot": "^1.25.3",
    "jszip": "^3.10.1",
    "katex": "^0.16.27",
    "next": "16.1.4",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.8",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.3"
  }
}
