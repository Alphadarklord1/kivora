<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Allow JIT compilation (required by llama.cpp / llama-server) -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Allow unsigned executable memory (required by llama.cpp Metal / GGML) -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Allow loading unsigned dylibs bundled with llama-server -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Outbound network for model downloads and Grok/OpenAI API calls -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Read/write access to user-selected files (PDF, Word, PowerPoint upload) -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>

  <!-- Read/write to Downloads folder (model .gguf files land here first) -->
  <key>com.apple.security.files.downloads.read-write</key>
  <true/>

  <!-- Full-disk access is NOT requested — only app-container and user-selected -->
</dict>
</plist>
